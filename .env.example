PORT=3000

# 必填：服务端 Supabase 凭据
SUPABASE_URL=
SUPABASE_KEY=

# 必填：OurHome 登录与令牌签名
APP_PASSWORD=
APP_TOKEN_SECRET=
APP_TOKEN_TTL_DAYS=180

# 可选：没有 API 站点档案时的后备线路
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE_URL=https://api.anthropic.com/v1

# 可选：记忆向量
JINA_API_KEY=

# 可选但推荐：网页推送（必须是一对新生成的密钥）
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ourhome@example.com
